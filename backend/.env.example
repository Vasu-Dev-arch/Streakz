# ── Server ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/progress-tracker
PORT=5000

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# Local dev: http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get these from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Local dev:   http://localhost:5000/api/auth/google/callback
# Production:  https://your-backend.onrender.com/api/auth/google/callback
# ⚠️  This MUST match exactly what you register in Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
